FLASK_APP=wsgi.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=dev-secret-key-change-in-production
SQLALCHEMY_DATABASE_URI=sqlite:///albricias.db
API_TOKEN=your-super-secret-token

# Newspaper identity
NEWSPAPER_NAME=¡Albricias!
NEWSPAPER_TAGLINE="All the News That's Fit to Print"
NEWSPAPER_PRICE=Two Cents
NEWSPAPER_METADATA_RIGHT="This is a test"

# Admin
ADMIN_PASSWORD=change-me-in-production

# GitHub integration (personal access token + your username)
GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_USERNAME=your_github_username

# OpenAI (for AI-assisted article generation)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Spotify (for listening data in monthly editions)
# 1. Create an app at https://developer.spotify.com/dashboard
# 2. Add the redirect URI below to your Spotify app's "Redirect URIs" list
# 3. Visit /admin/spotify/connect to authorise your account
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:5000/admin/spotify/callback

