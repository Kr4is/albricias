FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=dev-secret-key-change-in-production
SQLALCHEMY_DATABASE_URI=sqlite:///albricias.db
API_TOKEN=your-super-secret-token

# Newspaper identity
NEWSPAPER_NAME=¡Albricias!
NEWSPAPER_TAGLINE=All the News That's Fit to Print
NEWSPAPER_PRICE=Two Cents
NEWSPAPER_METADATA_RIGHT=

# Admin
ADMIN_PASSWORD=change-me-in-production

# GitHub integration (personal access token + your username)
GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_USERNAME=your_github_username

# OpenAI (for AI-assisted article generation)
OPENAI_API_KEY=sk-your-openai-api-key-here
